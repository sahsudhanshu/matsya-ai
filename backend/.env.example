# Backend Environment Variables
PORT=3005

# AWS Configuration
AWS_REGION=ap-south-1

# DynamoDB Tables
DYNAMODB_IMAGES_TABLE=ai-bharat-images
DYNAMODB_CHATS_TABLE=ai-bharat-chats
DYNAMODB_USERS_TABLE=ai-bharat-users
GROUPS_TABLE=ai-bharat-groups
DYNAMODB_OFFLINE_ANALYSES_TABLE=ai-bharat-offline-analyses

# S3 Configuration
S3_BUCKET_NAME=your-s3-bucket-name

# Authentication (Cognito & JWT)
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
JWT_SECRET=your-jwt-secret

# External APIs
ML_API_URL=https://your-ml-api.example.com/predict
ML_API_KEY=your-ml-api-key
CHAT_API_URL=http://localhost:8001/chat
CHAT_API_KEY=your-chat-api-key
OPENWEATHERMAP_API_KEY=your-openweathermap-key
