# Agent Environment Variables
APP_ENV=development
PORT=8001

# AWS Configuration
AWS_REGION=ap-south-1

# Google Gemini API
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# AWS Bedrock API (Alternative to Gemini)
USE_GEMINI=true
BEDROCK_LLM_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_API_KEY=

# DynamoDB Tables (Agent specific)
DYNAMODB_CONVERSATIONS_TABLE=ai-bharat-agent-conversations
DYNAMODB_MESSAGES_TABLE=ai-bharat-agent-messages
DYNAMODB_MEMORY_TABLE=ai-bharat-agent-memory

# DynamoDB Tables (Backend shared)
DYNAMODB_IMAGES_TABLE=ai-bharat-images
DYNAMODB_CHATS_TABLE=ai-bharat-chats
DYNAMODB_USERS_TABLE=ai-bharat-users
GROUPS_TABLE=ai-bharat-groups

# Authentication (Cognito)
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id

# External APIs
OPENWEATHERMAP_API_KEY=your-openweathermap-key
TAVILY_API_KEY=your-tavily-api-key
FISH_WEIGHT_API_URL=https://your-fish-weight-api.example.com

# Telegram Integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_SUBS_TABLE=ai-bharat-telegram-subs
TELEGRAM_ALERTS_ENABLED=true
