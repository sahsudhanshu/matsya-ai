{
  "expo": {
    "name": "Matsya AI",
    "slug": "ocean-ai-fisherman",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "mastyaai",
    "assetBundlePatterns": [
      "assets/**",
      "assets/models/**"
    ],
    "splash": {
      "image": "./logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aiforbharat.mastyaai",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.aiforbharat.mastyaai",
      "softwareKeyboardLayoutMode": "pan",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDS6nXsW1GbHfUeKloAFG2ZUudeSPeN96Q"
        }
      }
    },
    "notification": {
      "color": "#1890ff",
      "androidMode": "default",
      "androidCollapsedTitle": "Mastya AI Alerts"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "react-native-fast-tflite",
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mastya AI to access your photos to upload fish images."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Mastya AI to use your location to tag your catch location."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1890ff"
        }
      ],
      "expo-font",
      "expo-mail-composer",
      "expo-asset",
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ccae7625-6eb4-4ba9-9d6f-cc39e06ed09b"
      }
    }
  }
}
