# Mobile Environment Variables

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3005

# Agent API (Optional but recommended)
EXPO_PUBLIC_AGENT_URL=http://localhost:8001

# Authentication (Cognito)
EXPO_PUBLIC_COGNITO_USER_POOL_ID=your-user-pool-id
EXPO_PUBLIC_COGNITO_CLIENT_ID=your-client-id

# External APIs
EXPO_PUBLIC_OWM_API_KEY=your-openweathermap-key

# App Links
EXPO_PUBLIC_WEB_URL=https://oceanai.app

# Telegram Integration (Optional)
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=Matsya AICompanionBot
