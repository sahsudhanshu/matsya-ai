# ─────────────────────────────────────────────────────────────────────────────
# .gitignore – Matsya AI Mobile (Expo / React Native)
# ─────────────────────────────────────────────────────────────────────────────
# Learn more: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── CNG (Continuous Native Generation) ───────────────────────────────────────
# ios/ and android/ are auto-generated by `npx expo prebuild`.
# They are NOT committed; regenerate with:  npx expo prebuild --clean
/ios
/android
.kotlin/

# ── Metro ─────────────────────────────────────────────────────────────────────
.metro-health-check*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Environment variables ─────────────────────────────────────────────────────
# Keep .env.example committed; ignore all real secrets.
.env
.env.local
.env.*.local

# ── Signing & certificates ────────────────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
*.orig.*

# ── Build outputs ─────────────────────────────────────────────────────────────
build/
*.apk
*.aab
*.ipa

# ── Assets – bundled model slot (intentionally empty) ─────────────────────────
# TFLite models live in models/ (tracked via Git LFS).
# assets/models/ holds only a README – .tflite files must NOT be bundled.
assets/models/*.tflite

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Python (backend / scripts) ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
backend/__pycache__/
backend/static/
backend/venv/
scripts/venv/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
